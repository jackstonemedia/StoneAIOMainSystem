generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  ownerId   String            @map("owner_id")
  plan      String            @default("free")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  members   WorkspaceMember[]
  agents    Agent[]
  contacts  Contact[]
  companies Company[]
  deals     Deal[]
  campaigns     Campaign[]
  forms         Form[]
  documents     Document[]
  apiKeys       ApiKey[]
  integrations  Integration[]
  appointments  Appointment[]
  reviews       Review[]
  conversations Conversation[]
  projects      Project[]
  pipelines     Pipeline[]
  tasks         Task[]
  smartLists    SmartList[]
  notifications Notification[]

  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String    @default("member")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@map("workspace_members")
}

model Agent {
  id          String         @id @default(uuid())
  workspaceId String         @map("workspace_id")
  name        String
  type        String
  status      String         @default("draft")
  config      String
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs        AgentRun[]
  messages    AgentMessage[]

  @@map("agents")
}

model AgentRun {
  id          String         @id @default(uuid())
  agentId     String         @map("agent_id")
  status      String
  startedAt   DateTime       @default(now()) @map("started_at")
  completedAt DateTime?      @map("completed_at")
  triggerData String?        @map("trigger_data")
  agent       Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  steps       AgentRunStep[]

  @@map("agent_runs")
}

model AgentRunStep {
  id        String   @id @default(uuid())
  runId     String   @map("run_id")
  nodeId    String   @map("node_id")
  status    String
  output    String?
  error     String?
  startedAt DateTime @default(now()) @map("started_at")
  duration  Int?
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("agent_run_steps")
}

model AgentMessage {
  id        String   @id @default(uuid())
  agentId   String?  @map("agent_id")
  userId    String   @map("user_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@map("agent_messages")
}

model Contact {
  id              String          @id @default(uuid())
  workspaceId     String          @map("workspace_id")
  companyId       String?         @map("company_id")
  firstName       String          @map("first_name")
  lastName        String          @map("last_name")
  email           String?
  phone           String?
  location        String?
  title           String?
  leadScore       Int             @default(0) @map("lead_score")
  about           String?
  tagsJson        String          @default("[]") @map("tags_json")
  source          String?
  status          String?
  color           String          @default("#7dd3fc")
  assignedUserId  String?         @map("assigned_user_id")
  customFieldsJson String?        @map("custom_fields_json")
  lastContactedAt DateTime?       @map("last_contacted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals           Deal[]
  tasks           Task[]
  appointments    Appointment[]
  conversations   Conversation[]
  events          ContactEvent[]
  smartListItems  SmartListItem[]

  @@map("contacts")
}

model Company {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  website     String?
  industry    String?
  location    String?
  employees   String?
  revenue     String?
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts    Contact[]
  deals       Deal[]

  @@map("companies")
}

model Deal {
  id              String         @id @default(uuid())
  workspaceId     String         @map("workspace_id")
  companyId       String?        @map("company_id")
  contactId       String?        @map("contact_id")
  pipelineStageId String?        @map("pipeline_stage_id")
  title           String
  amount          Float          @default(0)
  probability     Int            @default(0)
  priority        String         @default("medium")
  closeDate       DateTime?      @map("close_date")
  ownerId         String?        @map("owner_id")
  description     String?
  wonLostReason   String?        @map("won_lost_reason")
  daysInStage     Int            @default(0) @map("days_in_stage")
  lastActivity    DateTime?      @map("last_activity")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  activities      Activity[]

  @@map("deals")
}

model Task {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  contactId   String?   @map("contact_id")
  title       String
  description String?
  type        String    @default("follow_up")
  dueDate     DateTime? @map("due_date")
  priority    String    @default("medium")
  status      String    @default("pending")
  assigneeId  String?   @map("assignee_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Activity {
  id          String   @id @default(uuid())
  workspaceId String?  @map("workspace_id")
  dealId      String?  @map("deal_id")
  contactId   String?  @map("contact_id")
  type        String
  title       String
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Campaign {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  name          String
  status        String    @default("draft")
  type          String
  subject       String?
  previewText   String?   @map("preview_text")
  content       String?
  audienceJson  String?   @map("audience_json")
  metricsJson   String?   @map("metrics_json")
  scheduledFor  DateTime? @map("scheduled_for")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("campaigns")
}

model Form {
  id          String           @id @default(uuid())
  workspaceId String           @map("workspace_id")
  name        String
  description String?
  schema      String
  visits      Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  data        String
  submittedAt DateTime @default(now()) @map("submitted_at")
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}

model Document {
  id          String          @id @default(uuid())
  workspaceId String          @map("workspace_id")
  title       String
  content     String
  type        String
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks      DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  content    String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model ApiKey {
  id           String    @id @default(uuid())
  workspaceId  String    @map("workspace_id")
  provider     String
  keyEncrypted String    @map("key_encrypted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@map("api_keys")
}

model Integration {
  id           String    @id @default(uuid())
  workspaceId  String    @map("workspace_id")
  provider     String    // e.g. facebook, instagram, linkedin, tiktok
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  scopes       String?
  expiresAt    DateTime? @map("expires_at")
  accountId    String?   @map("account_id") // Provider's account identifier
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@map("integrations")
}

model Appointment {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  title       String
  description String?
  type        String    @default("meeting")
  location    String?
  contactId   String?   @map("contact_id")
  startTime   DateTime  @map("start_time")
  endTime     DateTime  @map("end_time")
  status      String    @default("scheduled")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@map("appointments")
}

model Review {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  author      String
  rating      Int
  text        String?
  source      String    @default("google")
  date        DateTime  @default(now())
  replied     Boolean   @default(false)
  replyText   String?   @map("reply_text")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Conversation {
  id          String               @id @default(uuid())
  workspaceId String               @map("workspace_id")
  contactId   String?              @map("contact_id")
  channel     String               @default("sms")
  status      String               @default("open")
  unreadCount Int                  @default(0) @map("unread_count")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages    ConversationMessage[]

  @@map("conversations")
}

model ConversationMessage {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  sender         String
  body           String
  direction      String       @default("outbound")
  attachments    String?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_messages")
}

model ContactEvent {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  type      String
  title     String
  content   String?
  metadataJson String? @map("metadata_json")
  createdAt DateTime @default(now()) @map("created_at")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_events")
}

model Pipeline {
  id          String          @id @default(uuid())
  workspaceId String          @map("workspace_id")
  name        String
  isDefault   Boolean         @default(false) @map("is_default")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages      PipelineStage[]

  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  pipelineId  String   @map("pipeline_id")
  name        String
  color       String   @default("#52677D")
  order       Int      @default(0)
  probability Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@map("pipeline_stages")
}

model Project {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  description String?
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model SmartList {
  id          String          @id @default(uuid())
  workspaceId String          @map("workspace_id")
  name        String
  filtersJson String          @default("[]") @map("filters_json")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       SmartListItem[]

  @@map("smart_lists")
}

model SmartListItem {
  id          String    @id @default(uuid())
  smartListId String    @map("smart_list_id")
  contactId   String    @map("contact_id")
  addedAt     DateTime  @default(now()) @map("added_at")
  smartList   SmartList @relation(fields: [smartListId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([smartListId, contactId])
  @@map("smart_list_items")
}

model Notification {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  title       String
  body        String?
  type        String    @default("info")
  read        Boolean   @default(false)
  link        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
