# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# APP_URL: The URL where this app is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
VITE_APP_URL="http://localhost:3000"

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev — default if DATABASE_URL is not set):
# Leave empty to use file:./prisma/dev.db
#
# PostgreSQL (production — use Neon: https://neon.tech or Supabase: https://supabase.com):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_URL=""

# ─── AI ───────────────────────────────────────────────────────────────────────
# Gemini API key — server-side only. Never expose this to the frontend.
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=""

# ─── Voice (Retell) ───────────────────────────────────────────────────────────
# Get from: https://app.retellai.com/settings
RETELL_API_KEY=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── OAuth Integrations ───────────────────────────────────────────────────────
# Meta (Facebook / Instagram)
META_CLIENT_ID=""
META_CLIENT_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""

# TikTok
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# LinkedIn
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
